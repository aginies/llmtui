<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.llm-manager" path="/org/gnome/shell/extensions/llm-manager/">
    <key name="metrics-url" type="s">
      <default>"http://127.0.0.1:8080/metrics"</default>
      <summary>Metrics URL</summary>
      <description>LLM server metrics URL (used to derive WebSocket URL)</description>
    </key>
    <key name="update-time" type="i">
      <default>3</default>
      <summary>Seconds between updates</summary>
      <description>Delay between WebSocket reconnections</description>
    </key>
    <key name="position-in-panel" type="i">
      <default>2</default>
      <summary>Position in panel</summary>
      <description>Position in Panel (0=left, 1=center, 2=right, 3=far left, 4=far right)</description>
    </key>
    <key name="selected-metrics" type="as">
      <default>['model_name', 'tps', 'prompt_tps', 'gen_tps', 'ctx', 'vram', 'ram', 'cpu', 'decoded_tokens']</default>
      <summary>Selected metrics</summary>
      <description>The keys of the metrics currently selected to display in the top bar and menu.</description>
    </key>
   <key name="metrics-secret" type="s">
      <default>""</default>
      <summary>Metrics Secret</summary>
      <description>Secret to use for WebSocket authentication (appended as auth query parameter)</description>
    </key>
  </schema>
</schemalist>
